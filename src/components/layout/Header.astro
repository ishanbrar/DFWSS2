---
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { siteConfig, menuLinks } from "@/site.config";
import { Icon } from "astro-icon/components";
---

<header
	id="main-header"
	class="fixed left-0 top-0 z-20 flex h-20 w-full items-center overflow-hidden border-b border-color-150/50 bg-bgColor/80 px-4 backdrop-blur-md transition-all duration-300 ease-out md:relative md:h-auto md:border-b md:border-color-150/60 md:bg-transparent md:px-0"
>
	<div class="pointer-events-none absolute left-1/2 top-0 -ml-[50vw] min-h-screen w-screen md:hidden" aria-hidden="true">
		<div
			class="industrial-gradient-orb absolute top-[-90%] right-[10%] h-full w-[65%] bg-gradient-to-b from-color-150/50 to-transparent"
		>
		</div>
	</div>

	<div class="w-full justify-between sm:flex-col">
		<div class="flex items-center gap-x-4">
			<a
				aria-label={siteConfig.title}
				aria-current={Astro.url.pathname === "/" ? "page" : false}
				class="group flex h-8 items-center hover:filter-none sm:relative"
				href="/"
			>
				<div title={siteConfig.title}>
					<img
						src="/assets/images/DFWSS-2.png"
						alt={siteConfig.title}
						class="inline-block h-20 w-20 object-contain drop-shadow-industrial transition-transform duration-300 ease-out group-hover:scale-[1.02] md:h-24 md:w-24"
					/>
				</div>

				<strong
					class="'max-[320px]:hidden' z-10 mb-0.5 ms-3 hidden font-display text-xl font-semibold tracking-tighter text-accent-base transition-colors duration-300 ease-out group-hover:text-accent-one md:block lg:text-2xl"
				>
					{siteConfig.title}
				</strong>
			</a>
			<nav
				aria-label="Main menu"
				class="top-20 mx-auto ml-4 ml-auto hidden flex-col items-end justify-center gap-x-8 rounded-sm text-sm font-mono uppercase tracking-[0.15em] text-accent-base transition-all duration-300 ease-out group-[.menu-open]:z-50 group-[.menu-open]:flex sm:static sm:z-auto sm:flex-row sm:items-center sm:rounded-none sm:bg-transparent sm:shadow-none sm:backdrop-blur-none md:flex"
				id="main-navigation-menu"
			>
				{
					menuLinks.map((link) => (
						<a
							aria-current={Astro.url.pathname === link.path ? "page" : false}
							class="underline-offset-4 transition-all duration-300 ease-out hover:text-accent-one hover:underline decoration-color-300"
							data-astro-prefetch
							href={link.path}
						>
							{link.title}
						</a>
					))
				}

				<a class="industrial-btn-ghost flex h-9 items-center px-4" data-astro-prefetch href="/contact">
					Contact
				</a>
			</nav>

			<div class="ml-auto w-fit">
				<div id="buttons-panel" class="top-4 md:top-8 -ml-[4.5rem] flex space-x-4 items-center">
					<a
						href="https://constitution.congress.gov/constitution/amendment-2/"
						target="_blank"
						rel="noopener noreferrer"
						class="flex h-8 items-center justify-center rounded-sm border border-transparent transition-all duration-300 ease-out hover:border-color-200 hover:bg-color-75 active:scale-[0.98]"
						aria-label="Second Amendment - US Constitution"
					>
						<img
							src="/assets/images/USflag.png"
							alt="US Flag"
							class="h-6 w-auto drop-shadow-[0px_1.5px_1.5px_rgba(0,0,0,0.175)]"
						/>
					</a>
					<ThemeToggle />
				</div>
			</div>

			<mobile-button
				aria-expanded="false"
				aria-haspopup="menu"
				aria-label="Open main menu"
				class="group relative h-8 w-8 rounded-sm border border-color-200 bg-color-75/80 text-accent-base backdrop-blur-sm transition-all duration-300 ease-out hover:border-color-300 hover:bg-color-100 active:scale-[0.98] md:invisible md:hidden"
				id="toggle-nav-menu-mobile"
				type="button"
			>
				<Icon
					id="open-nav-menu-icon"
					aria-hidden="true"
					class="absolute start-1/2 top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 scale-100 opacity-100 transition-all duration-300"
					focusable="false"
					name="hugeicons:menu-01"
				/>
				<Icon
					id="close-nav-menu-icon"
					aria-hidden="true"
					class="absolute start-1/2 top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 scale-0 opacity-0 transition-all duration-300"
					focusable="false"
					name="hugeicons:cancel-01"
				/>
			</mobile-button>
		</div>
	</div>
</header>

<div id="drawer" class="fixed inset-0 z-10 hidden" aria-hidden="true">
	<div
		id="drawer-body"
		class="absolute inset-0 -translate-y-full transform border-t border-color-150 bg-bgColor/95 backdrop-blur-lg transition-all duration-300 ease-out"
	>
		<div class="pointer-events-none fixed left-1/2 top-0 -ml-[50vw] min-h-screen w-screen overflow-x-hidden" aria-hidden="true">
			<div
				class="industrial-gradient-orb absolute top-[-85%] right-[15%] h-full w-[65%] bg-gradient-to-b from-color-150/40 to-transparent"
			>
			</div>
		</div>

		<nav
			aria-label="Mobile navigation menu"
			class="absolute inset-0 flex flex-col items-center justify-center gap-y-8 text-center font-display text-2xl font-semibold tracking-tighter text-accent-base"
			id="nav-menu-mobile"
		>
			{
				menuLinks.map((link) => (
					<a
						aria-current={Astro.url.pathname === link.path ? "page" : false}
						class="font-mono text-sm uppercase tracking-[0.2em] underline-offset-4 transition-all duration-300 ease-out hover:text-accent-one hover:underline"
						data-astro-prefetch
						href={link.path}
					>
						{link.title}
					</a>
				))
			}
			<a class="industrial-btn-ghost px-6" data-astro-prefetch href="/contact"> Contact </a>
		</nav>
	</div>
</div>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const toggleNavMenuMobileButton = document.getElementById("toggle-nav-menu-mobile");
		const openMenuIcon = document.getElementById("open-nav-menu-icon");
		const closeMenuIcon = document.getElementById("close-nav-menu-icon");
		const drawer = document.getElementById("drawer");

		if (!toggleNavMenuMobileButton || !openMenuIcon || !closeMenuIcon || !drawer) {
			console.error("One or more required elements are missing in the DOM.");
			return;
		}

		const drawerBody = document.getElementById("drawer-body");
		if (!drawerBody) {
			console.error("Drawer body element is missing in the DOM.");
			return;
		}

		toggleNavMenuMobileButton.addEventListener("click", () => {
			const isOpen = toggleNavMenuMobileButton.getAttribute("aria-expanded") === "true";

			if (isOpen) {
				drawerBody.classList.add("opacity-0", "-translate-y-full");
				drawerBody.classList.remove("translate-y-0");

				setTimeout(() => {
					drawer.classList.add("hidden");
				}, 300);

				openMenuIcon.classList.add("scale-100", "opacity-100");
				closeMenuIcon.classList.add("scale-0", "opacity-0");
				closeMenuIcon.classList.remove("scale-100", "opacity-100");
			} else {
				drawer.classList.remove("hidden");
				drawerBody.classList.add("translate-y-0");
				drawerBody.classList.remove("opacity-0", "-translate-y-full");

				openMenuIcon.classList.add("scale-0", "opacity-0");
				closeMenuIcon.classList.add("scale-100", "opacity-100");
				openMenuIcon.classList.remove("scale-100", "opacity-100");
			}

			toggleNavMenuMobileButton.setAttribute("aria-expanded", (!isOpen).toString());
		});
	});
</script>
