---
import Search from "@/components/Search.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";
import { siteConfig, menuLinks } from "@/site.config";
import { Icon } from "astro-icon/components";
---

<header
	id="main-header"
	class="fixed left-0 top-0 z-20 flex h-20 w-full items-center overflow-hidden border-b border-black/15 bg-bgColor px-6 transition-all duration-700 md:relative md:h-auto md:px-16 dark:border-white/10"
	style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
>
	<div class="w-full justify-between sm:flex-col">
		<div class="flex items-center gap-x-6">
			<a
				aria-label={siteConfig.title}
				aria-current={Astro.url.pathname === "/" ? "page" : false}
				class="group flex h-8 items-center hover:filter-none sm:relative"
				href="/"
			>
				<div title={siteConfig.title}>
					<img
						src="/assets/images/DFWSS-2.png"
						alt={siteConfig.title}
						class="inline-block h-16 w-16 object-contain transition-transform duration-700 group-hover:scale-[1.02] md:h-20 md:w-20"
						style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
					/>
				</div>

				<strong
					class="'max-[320px]:hidden' z-10 mb-0.5 ms-4 hidden font-display text-lg font-black uppercase tracking-tighter text-black transition-colors duration-700 group-hover:opacity-70 md:block lg:text-xl dark:text-white"
					style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
				>
					{siteConfig.title}
				</strong>
			</a>
			<nav
				aria-label="Main menu"
				class="top-20 mx-auto ml-4 ml-auto hidden flex-col items-end justify-center gap-x-10 text-sm font-mono uppercase tracking-[0.25em] text-black transition-all duration-700 group-[.menu-open]:z-50 group-[.menu-open]:flex sm:static sm:z-auto sm:flex-row sm:items-center sm:rounded-none sm:bg-transparent sm:shadow-none dark:text-white md:flex"
				id="main-navigation-menu"
				style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
			>
				{
					menuLinks.map((link) => (
						<a
							aria-current={Astro.url.pathname === link.path ? "page" : false}
							class="underline-offset-4 transition-all duration-700 hover:underline"
							style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
							data-astro-prefetch
							href={link.path}
						>
							{link.title}
						</a>
					))
				}

				<a class="icomat-btn-ghost !w-auto !min-w-0 !px-4 !py-2" data-astro-prefetch href="/contact">
					<span>Contact</span>
				</a>
			</nav>

			<div class="ml-auto w-fit">
				<div id="buttons-panel" class="top-4 md:top-8 -ml-[4.5rem] flex space-x-4 items-center">
					<a
						href="https://constitution.congress.gov/constitution/amendment-2/"
						target="_blank"
						rel="noopener noreferrer"
						class="flex h-8 items-center justify-center rounded-none border border-transparent transition-all duration-700 hover:border-black/15 active:scale-[0.99] dark:hover:border-white/10"
						style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
						aria-label="Second Amendment - US Constitution"
					>
						<img
							src="/assets/images/USflag.png"
							alt="US Flag"
							class="h-6 w-auto"
						/>
					</a>
					<ThemeToggle />
				</div>
			</div>

			<mobile-button
				aria-expanded="false"
				aria-haspopup="menu"
				aria-label="Open main menu"
				class="group relative h-8 w-8 rounded-none border border-black/15 bg-transparent text-black transition-all duration-700 hover:border-black active:scale-[0.99] dark:border-white/10 dark:text-white md:invisible md:hidden"
				id="toggle-nav-menu-mobile"
				type="button"
				style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
			>
				<Icon
					id="open-nav-menu-icon"
					aria-hidden="true"
					class="absolute start-1/2 top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 scale-100 opacity-100 transition-all duration-700"
					style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
					focusable="false"
					name="hugeicons:menu-01"
				/>
				<Icon
					id="close-nav-menu-icon"
					aria-hidden="true"
					class="absolute start-1/2 top-1/2 h-6 w-6 -translate-x-1/2 -translate-y-1/2 scale-0 opacity-0 transition-all duration-700"
					style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
					focusable="false"
					name="hugeicons:cancel-01"
				/>
			</mobile-button>
		</div>
	</div>
</header>

<div id="drawer" class="fixed inset-0 z-10 hidden" aria-hidden="true">
	<div
		id="drawer-body"
		class="absolute inset-0 -translate-y-full transform border-t border-black/15 bg-bgColor transition-all duration-700 dark:border-white/10"
		style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
	>
		<nav
			aria-label="Mobile navigation menu"
			class="absolute inset-0 flex flex-col items-center justify-center gap-y-10 text-center font-display text-2xl font-black uppercase tracking-tighter text-black dark:text-white"
			id="nav-menu-mobile"
		>
			{
				menuLinks.map((link) => (
					<a
						aria-current={Astro.url.pathname === link.path ? "page" : false}
						class="font-mono text-xs uppercase tracking-[0.25em] underline-offset-4 transition-all duration-700 hover:underline"
						style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
						data-astro-prefetch
						href={link.path}
					>
						{link.title}
					</a>
				))
			}
			<a class="icomat-btn !w-auto" data-astro-prefetch href="/contact">
				<span>Contact</span>
			</a>
		</nav>
	</div>
</div>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const toggleNavMenuMobileButton = document.getElementById("toggle-nav-menu-mobile");
		const openMenuIcon = document.getElementById("open-nav-menu-icon");
		const closeMenuIcon = document.getElementById("close-nav-menu-icon");
		const drawer = document.getElementById("drawer");

		if (!toggleNavMenuMobileButton || !openMenuIcon || !closeMenuIcon || !drawer) {
			console.error("One or more required elements are missing in the DOM.");
			return;
		}

		const drawerBody = document.getElementById("drawer-body");
		if (!drawerBody) {
			console.error("Drawer body element is missing in the DOM.");
			return;
		}

		toggleNavMenuMobileButton.addEventListener("click", () => {
			const isOpen = toggleNavMenuMobileButton.getAttribute("aria-expanded") === "true";

			if (isOpen) {
				drawerBody.classList.add("opacity-0", "-translate-y-full");
				drawerBody.classList.remove("translate-y-0");

				setTimeout(() => {
					drawer.classList.add("hidden");
				}, 700);

				openMenuIcon.classList.add("scale-100", "opacity-100");
				closeMenuIcon.classList.add("scale-0", "opacity-0");
				closeMenuIcon.classList.remove("scale-100", "opacity-100");
			} else {
				drawer.classList.remove("hidden");
				drawerBody.classList.add("translate-y-0");
				drawerBody.classList.remove("opacity-0", "-translate-y-full");

				openMenuIcon.classList.add("scale-0", "opacity-0");
				closeMenuIcon.classList.add("scale-100", "opacity-100");
				openMenuIcon.classList.remove("scale-100", "opacity-100");
			}

			toggleNavMenuMobileButton.setAttribute("aria-expanded", (!isOpen).toString());
		});
	});
</script>
