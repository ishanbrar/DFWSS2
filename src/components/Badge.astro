---
const { variant = "default", showHash = true, title } = Astro.props;

// CSS-классы для вариантов стилей
const badgeClasses = {
	base: "flex h-6 items-baseline rounded-sm border border-color-200/80 px-2 pt-[0.075rem] text-xs font-medium tracking-wide shadow-editorial transition-all duration-200 ease-out active:scale-[0.98]",
	variants: {
		default: "bg-accent-base text-bgColor hover:bg-accent-one",
		accent: "bg-accent text-bgColor hover:opacity-90",
		"accent-base": "bg-accent-base text-bgColor hover:bg-accent-one",
		"accent-one": "bg-accent-one text-bgColor hover:bg-accent-two",
		"accent-two": "bg-accent-two text-bgColor hover:opacity-90",
		muted: "bg-color-100 text-textColor hover:border-accent-one/30 hover:bg-color-150",
		outline: "border-lightest text-textColor shadow-none",
		inactive: "bg-color-100 text-lighter shadow-none",
	},
};

const variantClasses = badgeClasses.variants[variant as keyof typeof badgeClasses.variants]; // Приведение типов
---

<div class={`${badgeClasses.base} ${variantClasses}`}>
	{showHash && <span class="h-full">#</span>}
	{title}
	<slot />
</div>
