---
interface Props {
	src: string;
	alt: string;
	class?: string;
}

const { src, alt, class: className = "" } = Astro.props;
---

<div class={`pointer-events-none absolute inset-0 overflow-hidden ${className}`} aria-hidden="true">
	<div class="icomat-zoom-wrap absolute inset-0">
		<img
			src={src}
			alt=""
			class="icomat-zoom-target absolute inset-0 h-full w-full object-cover object-center mix-blend-luminosity opacity-40 transition-opacity duration-700 group-hover:opacity-70 dark:opacity-35 dark:group-hover:opacity-60"
			style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);"
			loading="eager"
			decoding="async"
		/>
	</div>
	<div class="icomat-spotlight pointer-events-none absolute inset-0 dark:icomat-spotlight-dark"></div>
	<div
		class="pointer-events-none absolute inset-0 bg-gradient-to-b from-bgColor/90 via-bgColor/75 to-bgColor dark:from-bgColor/95 dark:via-bgColor/85 dark:to-bgColor"
	>
	</div>
</div>
