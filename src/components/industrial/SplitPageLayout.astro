---
interface Props {
	sectionLabel?: string;
	sectionNumber?: string;
	title: string;
	subtitle?: string;
}

const { sectionLabel, sectionNumber, title, subtitle } = Astro.props;
---

<div class="icomat-border-b grid w-full grid-cols-1 lg:grid-cols-12">
	<aside
		class="flex flex-col justify-between border-b border-black/15 px-6 py-32 md:px-16 md:py-56 lg:col-span-4 lg:sticky lg:top-0 lg:h-screen lg:self-start lg:border-b-0 lg:border-r dark:border-white/10"
		data-reveal
	>
		<div>
			{
				sectionNumber && (
					<p class="icomat-label mb-10">
						{sectionNumber}
						{sectionLabel && <> / {sectionLabel}</>}
					</p>
				)
			}
			<h1 class="icomat-display">{title}</h1>
			{
				subtitle && (
					<p class="mt-10 max-w-md font-sans text-base leading-relaxed tracking-wide text-black dark:text-white">
						{subtitle}
					</p>
				)
			}
		</div>
		<div class="mt-16 hidden h-px w-full bg-black/15 dark:bg-white/10 lg:block" aria-hidden="true"></div>
		<slot name="aside" />
	</aside>
	<div class="lg:col-span-8">
		<slot />
	</div>
</div>
