---
interface Props {
	number: string;
	visualSrc?: string;
	visualAlt?: string;
	class?: string;
}

const { number, visualSrc, visualAlt = "", class: className = "" } = Astro.props;
---

<section
	class={`icomat-border-b px-6 py-32 first:border-t-0 md:px-16 md:py-56 ${className}`}
	data-reveal
>
	<div class="mb-12 flex items-end justify-between gap-8 border-b border-black/15 pb-8 dark:border-white/10">
		<p class="font-mono text-6xl font-light leading-none tracking-tighter text-black md:text-8xl lg:text-9xl dark:text-white">
			{number}
		</p>
		<div class="hidden h-px flex-1 bg-black/15 dark:bg-white/10 md:block" aria-hidden="true"></div>
	</div>
	{
		visualSrc && (
			<div class="group relative mb-16 aspect-[16/10] max-h-[28rem] w-full overflow-hidden border border-black/15 dark:border-white/10">
				<div class="icomat-zoom-wrap absolute inset-0">
					<img
						src={visualSrc}
						alt={visualAlt}
						class="icomat-zoom-target absolute inset-0 h-full w-full object-cover object-center mix-blend-luminosity opacity-50 dark:opacity-40"
						loading="lazy"
						decoding="async"
					/>
				</div>
				<div class="icomat-spotlight pointer-events-none absolute inset-0 dark:icomat-spotlight-dark" />
				<div class="pointer-events-none absolute inset-0 bg-black/20 dark:bg-black/40" />
			</div>
		)
	}
	<div class="prose prose-citrus max-w-none dark:prose-invert">
		<slot />
	</div>
</section>
