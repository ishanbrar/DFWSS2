---
import BaseHead from "@/components/BaseHead.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;
---

<html
	class="overflow-x-hidden grid scroll-pt-24 scroll-smooth font-sans text-textColor text-xl md:text-base antialiased selection:bg-color-200/40 selection:text-accent-base"
	lang={siteConfig.lang}
>
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
	</head>
	<body class="relative m-auto min-h-screen w-full min-w-4xl max-w-[90rem] grow bg-bgColor text-textColor">
		<ThemeProvider />
		<SkipLink />

		<div class="pointer-events-none fixed top-0 left-1/2 -ml-[50vw] min-h-screen w-screen" aria-hidden="true">
			<div
				class="industrial-gradient-orb absolute top-[-70%] right-[5%] h-[120%] w-[55%] bg-gradient-to-b from-color-150/80 via-transparent to-transparent"
			>
			</div>
			<div
				class="industrial-gradient-orb absolute top-[-65%] left-[0%] h-[110%] w-[45%] bg-gradient-to-tr from-color-100/60 via-transparent to-transparent"
			>
			</div>
			<div class="industrial-metal-sheen absolute inset-0"></div>
		</div>

		<div class="relative flex min-h-screen w-full">
			<slot name="sidebar" />
			<div id="container" class="relative m-auto w-full max-w-[88rem] grow px-5 md:px-12 lg:px-16">
				<div class="m-auto grid min-h-screen md:grid-rows-[auto_auto_1fr] md:pt-4">
					<Header />
					<main id="main" class="relative flex-grow pt-28 md:pt-20">
						<slot />
					</main>
					<Footer />
				</div>
			</div>
		</div>

		<script is:inline>
			(() => {
				const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
				if (reduceMotion) {
					document.querySelectorAll("[data-reveal]").forEach((el) => el.classList.add("is-visible"));
					return;
				}
				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						}
					},
					{ rootMargin: "0px 0px -8% 0px", threshold: 0.08 },
				);
				const observe = () => {
					document.querySelectorAll("[data-reveal]:not(.is-visible)").forEach((el) => observer.observe(el));
				};
				observe();
				document.addEventListener("astro:page-load", observe);
			})();
		</script>
	</body>
</html>
