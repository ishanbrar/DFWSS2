---
import { type CollectionEntry, getCollection } from "astro:content";
import IndustrialCta from "@/components/industrial/IndustrialCta.astro";
import IndustrialHeroVisual from "@/components/industrial/IndustrialHeroVisual.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];

// Notes
const MAX_NOTES = 2;
const allNotes = await getCollection("note");
const latestNotes = allNotes.sort(collectionDateSort).slice(0, MAX_NOTES);
---

<PageLayout meta={{ title: "Home" }}>
	<section class="group relative -mx-5 mb-8 min-h-[92vh] overflow-hidden md:-mx-12 lg:-mx-16">
		<IndustrialHeroVisual
			src="/assets/images/industrial/hero-rifle.jpg"
			alt="Modern tactical platform — industrial studio presentation"
		/>

		<div class="relative grid min-h-[92vh] gap-16 py-24 md:py-32 lg:grid-cols-12 lg:gap-20 lg:py-40">
			<div class="flex flex-col justify-end px-5 md:px-0 lg:col-span-5 lg:sticky lg:top-28 lg:self-start" data-reveal>
				<p class="mb-8 font-mono text-xs uppercase tracking-[0.35em] text-lighter">01 / Foundation</p>
				<h1
					class="animate-industrial-hero font-display text-4xl font-semibold leading-[0.95] tracking-tighter text-accent-base sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl"
				>
					<span
						class="bg-gradient-to-br from-accent-base via-accent-one to-accent-two bg-clip-text text-transparent"
					>
						ਵਾਹਿਗੁਰੂ ਜੀ ਕਾ ਖਾਲਸਾ । ਵਾਹਿਗੁਰੂ ਜੀ ਕੀ ਫਤਹਿ ।
					</span>
				</h1>
				<p class="mt-6 font-mono text-sm tracking-wide text-lighter md:text-base">
					Waheguru Ji Ka Khalsa, Waheguru Ji Ki Fateh
				</p>
				<div class="mt-12 hidden h-px w-full max-w-xs bg-color-200 lg:block" aria-hidden="true"></div>
			</div>

			<div class="flex flex-col justify-center space-y-12 px-5 md:px-0 lg:col-span-7" data-reveal>
				<div class="industrial-glass p-8 md:p-10">
					<p class="text-lg leading-relaxed tracking-wide text-textColor/90">
						In Sikhi, the sword (ਕ੍ਰਿਪਾਨ) holds deep spiritual and temporal significance. It represents divine
						power, dignity, self-respect, and the Sikh commitment to defend the defenseless. As one of the Five
						Ks, it serves as a constant reminder of our responsibility to uphold justice and righteousness.
					</p>
				</div>

				<blockquote class="industrial-card border-l border-color-300 py-6 pl-8 pr-6 italic">
					"ਨਾਮੁ ਤਲਵਾਰੁ ਪੀਤੰਬਰੁ ਢਾਲਾ ॥<br />
					ਸਗਲ ਸੂਟੁ ਹਮਾਰਾ ॥"
					<br />
					<span class="mt-3 block font-mono text-xs not-italic tracking-wide text-lighter">
						"The Name is my sword; the Lord, my shield.<br />
						The entire body is my armor."<br />
						- Sri Guru Granth Sahib Ji (Ang 1072)
					</span>
				</blockquote>

				<div class="industrial-visual-frame relative overflow-hidden">
					<img
						src="/assets/images/DFWSS-2.png"
						alt="Kirpan - Sikh ceremonial sword"
						class="mx-auto w-full max-w-md object-contain p-8 transition-transform duration-300 ease-out hover:scale-[1.01]"
					/>
				</div>

				<div class="flex justify-start">
					<IndustrialCta href="/why/" label="Learn More" />
				</div>
			</div>
		</div>
	</section>
</PageLayout>
