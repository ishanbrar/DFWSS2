---
import { type CollectionEntry, getCollection } from "astro:content";
import SocialList from "@/components/SocialList.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import Note from "@/components/note/Note.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];

// Notes
const MAX_NOTES = 2;
const allNotes = await getCollection("note");
const latestNotes = allNotes.sort(collectionDateSort).slice(0, MAX_NOTES);
---

<PageLayout meta={{ title: "Home" }}>
	<!-- Hero section -->
	<!-- Background blur -->
	<div class="pointer-events-none absolute left-1/2 top-0 -ml-[50vw] min-h-screen w-screen overflow-x-hidden opacity-60 blur-3xl md:top-[-15%]" aria-hidden="true">
		<div class="editorial-gradient-orb absolute top-[5%] right-[-35%] h-full w-[60%] bg-gradient-to-b from-amber-200/70 via-stone-300/30 to-transparent"></div>
		<div class="editorial-gradient-orb absolute top-[8%] left-[-35%] h-full w-[55%] bg-gradient-to-b from-stone-400/40 to-transparent"></div>
	</div>
	 <section class="relative mx-auto flex max-w-2xl flex-col items-center justify-center px-2 py-16 md:py-20">
                <div class="w-full text-center">
            <span class="title animate-editorial-reveal bg-gradient-to-r from-accent-base via-accent-one to-accent-two bg-clip-text text-3xl font-display font-medium tracking-tight text-transparent md:text-4xl">
                ਵਾਹਿਗੁਰੂ ਜੀ ਕਾ ਖਾਲਸਾ । ਵਾਹਿਗੁਰੂ ਜੀ ਕੀ ਫਤਹਿ ।
            </span>
            <div class="mt-3 text-lg italic tracking-wide text-lighter">
                Waheguru Ji Ka Khalsa, Waheguru Ji Ki Fateh
            </div>
            
            <div class="mt-10 mb-8 text-lg leading-relaxed tracking-wide text-textColor/90">
                <p class="mb-6">
                    In Sikhi, the sword (ਕ੍ਰਿਪਾਨ) holds deep spiritual and temporal significance. It represents divine power, dignity, self-respect, and the Sikh commitment to defend the defenseless. As one of the Five Ks, it serves as a constant reminder of our responsibility to uphold justice and righteousness.
                </p>
                
                <blockquote class="editorial-card mb-10 border-l-2 border-accent-one py-4 pl-6 pr-4 italic">
                    "ਨਾਮੁ ਤਲਵਾਰੁ ਪੀਤੰਬਰੁ ਢਾਲਾ ॥<br/>
                    ਸਗਲ ਸੂਟੁ ਹਮਾਰਾ ॥"
                    <br/>
                    <span class="text-sm mt-2 block">
                        "The Name is my sword; the Lord, my shield.<br/>
                        The entire body is my armor."<br/>
                        - Sri Guru Granth Sahib Ji (Ang 1072)
                    </span>
                </blockquote>

                <div class="flex justify-center">
    <img 
        src="/assets/images/DFWSS-2.png" 
        alt="Kirpan - Sikh ceremonial sword" 
        class="w-96 h-auto"
    />
</div>
            </div>

            <div class="flex justify-center space-x-4 mt-8">
                <a href="/why/" class="editorial-btn relative flex h-11 items-center justify-center bg-gradient-to-r from-accent-one to-accent-two px-8">
                    <span class="font-medium tracking-wide text-bgColor">
                        Learn More
                    </span>
                </a>
            </div>
        </div>
    </section>
</PageLayout>