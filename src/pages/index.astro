---
import { type CollectionEntry, getCollection } from "astro:content";
import IndustrialCta from "@/components/industrial/IndustrialCta.astro";
import IndustrialHeroVisual from "@/components/industrial/IndustrialHeroVisual.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

// Posts
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];

// Notes
const MAX_NOTES = 2;
const allNotes = await getCollection("note");
const latestNotes = allNotes.sort(collectionDateSort).slice(0, MAX_NOTES);
---

<PageLayout meta={{ title: "Home" }}>
	<section class="group relative min-h-screen overflow-hidden border-b border-black/15 dark:border-white/10">
		<IndustrialHeroVisual
			src="/assets/images/industrial/hero-rifle.jpg"
			alt="Modern tactical platform — industrial studio presentation"
		/>

		<div
			class="relative grid min-h-screen w-full grid-cols-1 gap-0 lg:grid-cols-12"
		>
			<div
				class="flex flex-col justify-between border-b border-black/15 px-6 py-32 md:px-16 md:py-56 lg:col-span-5 lg:sticky lg:top-0 lg:h-screen lg:border-b-0 lg:border-r dark:border-white/10"
				data-reveal
			>
				<div>
					<p class="icomat-label mb-12">01 / Foundation</p>
					<h1 class="animate-icomat-hero icomat-display">
						ਵਾਹਿਗੁਰੂ ਜੀ ਕਾ ਖਾਲਸਾ । ਵਾਹਿਗੁਰੂ ਜੀ ਕੀ ਫਤਹਿ ।
					</h1>
					<p class="mt-8 font-mono text-xs uppercase tracking-[0.25em] text-black dark:text-white">
						Waheguru Ji Ka Khalsa, Waheguru Ji Ki Fateh
					</p>
				</div>
				<div class="mt-16 hidden h-px w-full bg-black/15 dark:bg-white/10 lg:block" aria-hidden="true"></div>
			</div>

			<div
				class="flex flex-col justify-center space-y-0 lg:col-span-7"
				data-reveal
			>
				<div class="icomat-border-b px-6 py-32 md:px-16 md:py-56">
					<p class="font-sans text-lg leading-relaxed tracking-wide text-black dark:text-white">
						In Sikhi, the sword (ਕ੍ਰਿਪਾਨ) holds deep spiritual and temporal significance. It represents divine
						power, dignity, self-respect, and the Sikh commitment to defend the defenseless. As one of the Five
						Ks, it serves as a constant reminder of our responsibility to uphold justice and righteousness.
					</p>
				</div>

				<blockquote class="icomat-border-b icomat-quote px-6 py-32 md:px-16 md:py-56">
					"ਨਾਮੁ ਤਲਵਾਰੁ ਪੀਤੰਬਰੁ ਢਾਲਾ ॥<br />
					ਸਗਲ ਸੂਟੁ ਹਮਾਰਾ ॥"
					<br />
					<span class="mt-6 block font-mono text-xs not-italic uppercase tracking-[0.25em] text-black dark:text-white">
						"The Name is my sword; the Lord, my shield.<br />
						The entire body is my armor."<br />
						- Sri Guru Granth Sahib Ji (Ang 1072)
					</span>
				</blockquote>

				<div class="icomat-border-b px-6 py-32 md:px-16 md:py-56">
					<div class="icomat-zoom-wrap group relative mx-auto aspect-[4/3] max-w-lg overflow-hidden border border-black/15 dark:border-white/10">
						<img
							src="/assets/images/DFWSS-2.png"
							alt="Kirpan - Sikh ceremonial sword"
							class="icomat-zoom-target mx-auto w-full max-w-md object-contain p-12"
						/>
						<div class="icomat-spotlight pointer-events-none absolute inset-0 dark:icomat-spotlight-dark"></div>
					</div>
				</div>

				<div class="px-6 py-32 md:px-16 md:py-56">
					<IndustrialCta href="/why/" label="Learn More" />
				</div>
			</div>
		</div>
	</section>
</PageLayout>
